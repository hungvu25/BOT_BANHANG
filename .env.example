# Copy to .env trên máy deploy (cùng thư mục docker-compose) hoặc dán từng biến vào Portainer → Stack → Environment.
# Bắt buộc:
A_API_KEY=
B_API_KEY=

# SQLite trong container (khớp volume prisma trong compose):
DATABASE_URL=file:/app/apps/server/prisma/prod.db

# CORS: URL admin thật (ví dụ http://IP:5173 hoặc https://admin.domain.com)
ADMIN_ORIGIN=http://localhost:5173

# Tuỳ chọn (có default trong code):
# PORT=3000
# A_BASE_URL=https://datammo.com
# B_BASE_URL=http://example.com
# POLL_INTERVAL_MS=5000
# AUTO_PROCESS_ORDERS=false
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
